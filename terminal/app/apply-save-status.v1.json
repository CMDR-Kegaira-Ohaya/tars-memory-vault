{
  "id": "terminal-apply-save-status-v1",
  "version": "v1",
  "role": "pages-runtime-apply-save-status-surface-contract",
  "uses": {
    "saveManager": "terminal/app/save-manager.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json",
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json"
  },
  "inputs": [
    "requestEnabled",
    "consentGranted",
    "markerStatus",
    "saveTag",
    "writeRoot"
  ],
  "fields": [
    "consentRequired",
    "consentGranted",
    "status",
    "statusDetail",
    "handoffTarget",
    "repoHandlerTarget",
    "verificationRequired"
  ],
  "statusStages": "terminal-save-manager-v1.statusStages",
  "states": {
    "disabledNoRequest": {
      "match": {
        "requestEnabled": false
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": false,
        "status": "disabled",
        "statusDetail": "no-staged-request",
        "handoffTarget": "none",
        "repoHandlerTarget": "none",
        "verificationRequired": false
      }
    },
    "stagedOnly": {
      "match": {
        "requestEnabled": true,
        "markerStatus": "staged-only"
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": "from-marker-consent",
        "status": "staged-only",
        "statusDetail": "client-staged-request-not-yet-handed-off",
        "handoffTarget": "apply-save-request-contract",
        "repoHandlerTarget": "repo-save-write-handler-contract",
        "verificationRequired": true
      }
    },
    "awaitingConsent": {
      "match": {
        "requestEnabled": true,
        "markerStatus": "awaiting-consent"
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": false,
        "status": "awaiting-consent",
        "statusDetail": "explicit-repo-write-consent-required-before-handoff",
        "handoffTarget": "apply-save-request-contract",
        "repoHandlerTarget": "repo-save-write-handler-contract",
        "verificationRequired": true
      }
    },
    "handedOff": {
      "match": {
        "requestEnabled": true,
        "markerStatus": "handed-off"
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": true,
        "status": "handed-off",
        "statusDetail": "client-marker-only-handoff-recorded-no-browser-repo-write-claimed",
        "handoffTarget": "apply-save-request-contract",
        "repoHandlerTarget": "repo-save-write-handler-contract",
        "verificationRequired": true
      }
    },
    "applied": {
      "match": {
        "requestEnabled": true,
        "markerStatus": "applied"
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": true,
        "status": "applied",
        "statusDetail": "client-status-marker-only-repo-verification-still-required-for-trust",
        "handoffTarget": "apply-save-request-contract",
        "repoHandlerTarget": "repo-save-write-handler-contract",
        "verificationRequired": true
      }
    },
    "rejected": {
      "match": {
        "requestEnabled": true,
        "markerStatus": "rejected"
      },
      "derive": {
        "consentRequired": true,
        "consentGranted": "from-marker-consent",
        "status": "rejected",
        "statusDetail": "request-rejected-or-not-approved-for-repo-write",
        "handoffTarget": "apply-save-request-contract",
        "repoHandlerTarget": "repo-save-write-handler-contract",
        "verificationRequired": false
      }
    }
  },
  "guardrails": [
    "Apply-save status is a Pages runtime status surface, not proof of a repo write by itself.",
    "Consent markers and local status markers must not pretend the browser wrote the repo directly.",
    "Boards are excluded because Boards never use terminal/saves/.",
    "Trusted success still depends on repo-side verification after an actual bounded write."
  ]
}
