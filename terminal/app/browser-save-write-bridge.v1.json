{
  "id": "terminal-browser-save-write-bridge-v1",
  "version": "v1",
  "role": "bounded-pages-runtime-staged-collections-ingest-request-bridge",
  "uses": {
    "saveManager": "terminal/app/save-manager.v1.json",
    "readerSessionSave": "terminal/app/reader-session-save.v1.json",
    "browserNoteEditor": "terminal/app/browser-note-editor.v1.json",
    "saveSlotIndex": "terminal/saves/save-slot-index.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json",
    "repoCollectionsIngestHandler": "terminal/app/repo-collections-ingest-handler.v1.json"
  },
  "appliesTo": [
    "repo-cartridge",
    "disk-cartridge",
    "drag-drop-cartridge"
  ],
  "excludes": [
    "repo-board"
  ],
  "stagingMode": "client-staged-ingest-request-only",
  "statusStages": "terminal-save-manager-v1.statusStages",
  "handoff": {
    "target": "terminal/app/apply-save-request.v1.json",
    "requiresExplicitRepoWriteConsent": true,
    "repoHandler": "terminal/app/repo-collections-ingest-handler.v1.json"
  },
  "requestShape": {
    "saveTag": "string",
    "sourceClass": "repo-cartridge-or-disk-cartridge-or-drag-drop-cartridge",
    "mountedId": "string",
    "manifestId": "string-or-null",
    "family": "collections-family-id",
    "slug": "kebab-case-string",
    "catalogId": "repo:<slug>",
    "kind": "string",
    "title": "string",
    "summary": "string-or-null",
    "runtime": "string-or-null",
    "mountable": "boolean",
    "packageRoot": "collections/<family>/<slug>/",
    "packageFiles": [
      {
        "path": "collections/<family>/<slug>/manifest.json-or-descendant",
        "payloadType": "object-or-text",
        "payload": "object-or-string"
      }
    ],
    "responseRoot": "terminal/saves/<saveTag>/",
    "responseArtifacts": [
      "terminal/saves/<saveTag>/repo-write-response.v1.json",
      "terminal/saves/<saveTag>/request-history-index.v1.json"
    ],
    "coverage": {
      "bookmarks": "tracked-or-declared-partial"
    },
    "status": "staged-only"
  },
  "guardrails": [
    "The bridge packages canonical collections-ingest requests but does not perform authenticated repo writes itself.",
    "Boards are excluded because Boards never use terminal/saves/ and are not canonical collections-ingest targets.",
    "The canonical repo target is collections/<family>/<slug>/ while response/history sidecars remain under terminal/saves/<saveTag>/ for operator inspection.",
    "A staged browser request is not itself a repo write until an explicit authenticated handoff applies it."
  ]
}
