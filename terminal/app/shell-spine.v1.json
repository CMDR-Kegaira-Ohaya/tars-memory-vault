{
  "id": "terminal-shell-spine-v1",
  "version": "v1",
  "role": "persistent-shell-contract",
  "runtimeRoot": "terminal/",
  "deliverySurface": {
    "target": "pages",
    "uiModel": "live-client-runtime",
    "staticMock": false,
    "replacesGptSide": false
  },
  "authorityModel": {
    "runtime": "terminal-pages-shell",
    "planning": "gpt-side-and-working-board",
    "repoSourceOfTruth": "repo-paths-and-working-board"
  },
  "modes": [
    {
      "id": "home",
      "label": "Home"
    },
    {
      "id": "collections",
      "label": "Collections",
      "contentRoot": "collections/"
    },
    {
      "id": "boards",
      "label": "Boards",
      "approvedRoot": "work/dev/projects/",
      "readOnly": true
    },
    {
      "id": "cartridges",
      "label": "Cartridges"
    },
    {
      "id": "runs",
      "label": "Runs"
    },
    {
      "id": "saves",
      "label": "Saves"
    },
    {
      "id": "system",
      "label": "System"
    }
  ],
  "boundaries": {
    "save": {
      "writeRoot": "terminal/saves/<tag>/",
      "distinctFromExport": true,
      "repoMutationByDefault": false
    },
    "boards": {
      "liveReadoutOnly": true,
      "saveThroughGui": false,
      "usesTerminalSaves": false,
      "exportSource": "enabled",
      "exportOutput": "placeholder-disabled"
    },
    "runtimeInteraction": {
      "pageTurnsAreRuntimeState": true,
      "notesAreTerminalState": true,
      "notesDoNotEditSource": true,
      "laterGamesAreRuntimeState": true
    }
  },
  "stateShape": {
    "currentMode": "Home",
    "mountedId": null,
    "mountedKind": null,
    "sourcePath": null,
    "sourceClass": null,
    "renderer": null,
    "engine": null,
    "saveTag": null,
    "save": "disabled",
    "exportSource": "disabled",
    "exportOutput": "placeholder",
    "dirty": null,
    "interaction": {
      "page": null,
      "scroll": null,
      "notes": false,
      "runtimeSession": null
    },
    "state": "idle"
  }
}
