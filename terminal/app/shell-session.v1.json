{
  "id": "terminal-shell-session-v1",
  "version": "v1",
  "role": "shell-session-runtime-contract",
  "uses": {
    "shellSpine": "terminal/app/shell-spine.v1.json",
    "modeResolver": "terminal/loaders/mode-resolver.v1.json",
    "manifestSelection": "terminal/manifests/repo-manifest-selection.v1.json",
    "boardEnumeration": "terminal/app/board-enumeration.v1.json",
    "saveSlotIndex": "terminal/saves/save-slot-index.v1.json",
    "mountState": "terminal/app/mount-state.v1.json",
    "rendererSelection": "terminal/renderers/renderer-selection.v1.json",
    "mountedViewport": "terminal/app/mounted-viewport.v1.json",
    "actionState": "terminal/app/action-state.v1.json",
    "statusStrip": "terminal/app/status-strip.v1.json",
    "boardsMode": "terminal/app/boards-mode.v1.json",
    "readerSessionSave": "terminal/app/reader-session-save.v1.json"
  },
  "initialState": {
    "currentMode": "home",
    "mountedId": null,
    "mountedKind": null,
    "sourcePath": null,
    "sourceClass": null,
    "renderer": null,
    "engine": null,
    "saveTag": null,
    "save": "disabled",
    "exportSource": "disabled",
    "exportOutput": "placeholder",
    "dirty": null,
    "interaction": {
      "page": null,
      "scroll": null,
      "notes": false,
      "runtimeSession": null
    },
    "actionState": {
      "save": "disabled",
      "exportSource": "disabled",
      "exportOutput": "placeholder-disabled",
      "notes": "disabled",
      "bookmarks": "disabled"
    },
    "statusStrip": {
      "mode": "HOME",
      "source": "none",
      "mountedKind": "none",
      "state": "idle",
      "renderer": "none",
      "engine": "none",
      "save": "disabled",
      "exportSource": "disabled",
      "exportOutput": "placeholder-disabled"
    },
    "mountedViewport": {
      "surface": "RUNS",
      "displayMode": "empty-shell-placeholder",
      "source": "none",
      "mountedKind": "none",
      "renderer": "none",
      "engine": "none",
      "readOnly": true,
      "sessionPersistence": "none",
      "viewState": "idle"
    },
    "state": "idle"
  },
  "transitions": {
    "boot": {
      "from": ["idle", "suspended", null],
      "to": "idle",
      "effect": "initialize-shell-session-and-derive-action-state-and-status-strip-and-mounted-viewport"
    },
    "switchMode": {
      "from": ["idle", "mounted", "running"],
      "to": "idle",
      "effect": "change-current-mode-without-implicit-mount-and-refresh-action-state-and-status-strip-and-mounted-viewport"
    },
    "selectManifest": {
      "from": ["idle", "mounted"],
      "to": "idle",
      "effect": "resolve-canonical-repo-cartridge-from-manifest-before-mount"
    },
    "selectBoard": {
      "from": ["idle", "mounted"],
      "to": "idle",
      "effect": "resolve-approved-live-board-from-board-enumeration-before-mount"
    },
    "selectSaveSlot": {
      "from": ["idle", "mounted"],
      "to": "idle",
      "effect": "resolve-bounded-runtime-state-from-save-slot-index-before-resume"
    },
    "mountResolvedSource": {
      "from": ["idle", "mounted"],
      "to": "mounted",
      "requires": [
        "currentMode",
        "sourcePath",
        "sourceClass"
      ],
      "effect": "derive-mounted-item-shape-then-resolve-renderer-then-derive-action-state-then-derive-status-strip-then-derive-mounted-viewport-then-set-session-fields"
    },
    "updateInteraction": {
      "from": ["mounted", "running"],
      "to": "mounted",
      "effect": "update-page-scroll-notes-and-runtime-session-and-refresh-action-state-and-status-strip-and-mounted-viewport"
    },
    "runMountedItem": {
      "from": ["mounted"],
      "to": "running",
      "effect": "activate-renderer-or-engine-without-changing-source-and-preserve-action-state-and-refresh-status-strip-and-mounted-viewport"
    },
    "unmount": {
      "from": ["mounted", "running"],
      "to": "idle",
      "effect": "clear-mounted-fields-keep-current-mode-and-reset-action-state-and-status-strip-and-mounted-viewport"
    }
  },
  "modeRules": {
    "boards": {
      "allowedSourceClass": "repo-board",
      "preferredSelection": "board-enumeration-driven",
      "mountedKind": "board",
      "save": "disabled",
      "notes": "disabled",
      "bookmarks": "disabled",
      "sessionPersistence": "ephemeral-only"
    },
    "collections": {
      "preferredSourceClass": "repo-cartridge",
      "preferredSelection": "manifest-driven-when-available",
      "mountedKind": "cartridge",
      "sessionPersistence": "allowed-via-terminal-saves"
    },
    "cartridges": {
      "allowedSourceClass": [
        "repo-cartridge",
        "disk-cartridge",
        "drag-drop-cartridge"
      ],
      "mountedKind": "cartridge",
      "sessionPersistence": "allowed-via-terminal-saves"
    },
    "saves": {
      "preferredSelection": "save-slot-index-driven",
      "allowedSourceClass": [
        "repo-cartridge",
        "disk-cartridge",
        "drag-drop-cartridge"
      ],
      "mountedKind": "cartridge",
      "sessionPersistence": "resume-from-terminal-saves"
    }
  },
  "saveEligibility": {
    "requires": [
      "save != disabled",
      "saveTag != null",
      "mountedKind != board",
      "sourceClass != repo-board"
    ],
    "writeRoot": "terminal/saves/<tag>/",
    "writes": [
      "state.json",
      "session.json",
      "notes.json"
    ]
  },
  "interactionRules": [
    "Page turns and scroll updates change runtime state, not mounted source files.",
    "Notes may exist only for save-eligible mounted cartridges.",
    "Boards mounts keep interaction state ephemeral and non-persisted.",
    "Export Source remains independent from save state."
  ],
  "statusDerivation": {
    "boards": {
      "state": "read-only-live-board",
      "save": "disabled",
      "exportSource": "enabled",
      "exportOutput": "placeholder-disabled"
    },
    "saveEligibleMount": {
      "state": "mounted",
      "save": "enabled-or-conditional",
      "exportSource": "conditional",
      "exportOutput": "placeholder"
    }
  }
}
