{
  "id": "terminal-pages-shell-entry-v1",
  "version": "v1",
  "role": "browser-facing-shell-entry-contract",
  "entryHtml": "terminal/index.html",
  "entryScript": "terminal/app/browser-runtime.js",
  "uses": {
    "pagesRuntime": "terminal/app/pages-runtime.v1.json",
    "browserResolver": "terminal/app/browser-resolver.v1.json",
    "browserSaveResume": "terminal/app/browser-save-resume.v1.json",
    "browserNoteEditor": "terminal/app/browser-note-editor.v1.json",
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json",
    "browserRuntime": "terminal/app/browser-runtime.js",
    "shellSession": "terminal/app/shell-session.v1.json",
    "manifestIndex": "terminal/manifests/manifest-index.v1.json",
    "boardEnumeration": "terminal/app/board-enumeration.v1.json"
  },
  "startup": {
    "load": [
      "shell-session-initial-state",
      "manifest-index",
      "board-enumeration",
      "save-slot-index",
      "browser-resolver-layer",
      "browser-save-resume-layer",
      "browser-note-editor-layer",
      "browser-save-write-bridge-layer",
      "apply-save-request-layer",
      "repo-save-write-handler-contract"
    ],
    "render": [
      "status-strip",
      "action-bar",
      "save-slot-list",
      "home-summary",
      "runs-viewport",
      "note-editor",
      "save-write-bridge-preview"
    ],
    "interaction": [
      "client-side-mode-switching",
      "contract-backed-example-cartridge-mounting",
      "contract-backed-live-board-mounting",
      "contract-backed-save-slot-resume",
      "contract-backed-note-editing-for-save-eligible-cartridges",
      "contract-backed-bounded-save-write-request-staging",
      "explicit-apply-save-request-handoff",
      "explicit-repo-side-bounded-save-write-handling",
      "client-side-unmount"
    ]
  },
  "guardrails": [
    "The browser shell is live client-side runtime, not a static mock image.",
    "The entry shell does not replace GPT-side planning or repo work.",
    "The entry shell does not perform repo writes outside terminal/saves/.",
    "Contract-backed browser resolution should consume landed repo contracts rather than duplicate shell rules ad hoc."
  ]
}
