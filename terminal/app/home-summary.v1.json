{
  "id": "terminal-home-summary-v1",
  "version": "v1",
  "role": "home-mode-summary-derivation-contract",
  "uses": {
    "actionState": "terminal/app/action-state.v1.json",
    "statusStrip": "terminal/app/status-strip.v1.json",
    "mountedViewport": "terminal/app/mounted-viewport.v1.json",
    "saveSlotIndex": "terminal/saves/save-slot-index.v1.json"
  },
  "inputs": [
    "currentMode",
    "mountedId",
    "mountedKind",
    "sourcePath",
    "sourceClass",
    "renderer",
    "engine",
    "saveTag",
    "actionState",
    "statusStrip",
    "mountedViewport",
    "saveSlotIndex"
  ],
  "fields": [
    "mode",
    "currentMount",
    "recentSave",
    "currentAvailability",
    "quickActions",
    "runsSurface",
    "notesState"
  ],
  "states": {
    "noMount": {
      "match": {
        "mountedKind": null
      },
      "derive": {
        "mode": "HOME",
        "currentMount": "none",
        "recentSave": "from-save-slot-index-if-present",
        "currentAvailability": {
          "save": "disabled",
          "exportSource": "disabled",
          "exportOutput": "placeholder-disabled"
        },
        "quickActions": [
          "open-collections",
          "open-boards",
          "open-saves"
        ],
        "runsSurface": "idle-placeholder",
        "notesState": "disabled"
      }
    },
    "boardMount": {
      "match": {
        "mountedKind": "board",
        "sourceClass": "repo-board"
      },
      "derive": {
        "mode": "HOME",
        "currentMount": "live-board",
        "recentSave": "not-applicable",
        "currentAvailability": {
          "save": "disabled",
          "exportSource": "enabled",
          "exportOutput": "placeholder-disabled"
        },
        "quickActions": [
          "resume-board-readout",
          "open-boards",
          "export-source"
        ],
        "runsSurface": "live-board-readout",
        "notesState": "disabled"
      }
    },
    "cartridgeMount": {
      "match": {
        "mountedKind": "cartridge"
      },
      "derive": {
        "mode": "HOME",
        "currentMount": "mounted-cartridge",
        "recentSave": "matching-save-tag-or-latest-related-save",
        "currentAvailability": {
          "save": "from-action-state",
          "exportSource": "from-action-state",
          "exportOutput": "from-action-state"
        },
        "quickActions": [
          "resume-runs",
          "open-saves",
          "export-source"
        ],
        "runsSurface": "from-mounted-viewport",
        "notesState": "from-action-state"
      }
    }
  },
  "guardrails": [
    "Home summary derives from existing shell state; it does not create new capabilities.",
    "Boards remain outside save-slot behavior even when summarized on Home.",
    "Quick actions reflect allowed runtime routes only.",
    "Home may show placeholder recent-save information before concrete save slots exist."
  ]
}
