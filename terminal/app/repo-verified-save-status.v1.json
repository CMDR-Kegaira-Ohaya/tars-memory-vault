{
  "id": "terminal-repo-verified-save-status-v1",
  "version": "v1",
  "role": "repo-verified-save-status-ingest-contract",
  "uses": {
    "saveManager": "terminal/app/save-manager.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json"
  },
  "inputs": [
    "responseLoaded",
    "responseStatus",
    "verificationHead",
    "verifiedPaths",
    "currentSaveTag"
  ],
  "fields": [
    "consumed",
    "status",
    "detail",
    "saveTag",
    "verifiedHead",
    "pathsVerified",
    "trusted"
  ],
  "statusStages": "terminal-save-manager-v1.statusStages",
  "states": {
    "noVerifiedResponse": {
      "match": {
        "responseLoaded": false
      },
      "derive": {
        "consumed": false,
        "status": "disabled",
        "detail": "no-repo-verified-handler-response-loaded",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "none",
        "pathsVerified": [],
        "trusted": false
      }
    },
    "verifiedApplied": {
      "match": {
        "responseLoaded": true,
        "responseStatus": "applied"
      },
      "derive": {
        "consumed": true,
        "status": "repo-verified-applied",
        "detail": "repo-verified-applied-state-from-handler-response",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "from-verified-response-head",
        "pathsVerified": "from-verified-response-paths",
        "trusted": true
      }
    },
    "verifiedRejected": {
      "match": {
        "responseLoaded": true,
        "responseStatus": "rejected"
      },
      "derive": {
        "consumed": true,
        "status": "rejected",
        "detail": "repo-handler-rejected-request",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "from-verified-response-head",
        "pathsVerified": "from-verified-response-paths",
        "trusted": false
      }
    },
    "verifiedOther": {
      "match": {
        "responseLoaded": true,
        "responseStatus": "awaiting-consent|handed-off|staged-only"
      },
      "derive": {
        "consumed": true,
        "status": "handed-off",
        "detail": "repo-response-loaded-but-not-verified-applied",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "from-verified-response-head",
        "pathsVerified": "from-verified-response-paths",
        "trusted": false
      }
    }
  },
  "guardrails": [
    "Repo-verified save status must consume a repo-handler response shape, not a browser-only marker.",
    "Repo-verified status is distinct from local apply markers in the Pages runtime.",
    "Trusted applied state depends on verified repo response content, not client-side status alone.",
    "Boards are excluded because Boards never use terminal/saves/."
  ]
}
