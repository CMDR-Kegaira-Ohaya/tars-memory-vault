{
  "id": "terminal-repo-verified-save-status-v1",
  "version": "v1",
  "role": "repo-verified-collections-ingest-status-contract",
  "uses": {
    "saveManager": "terminal/app/save-manager.v1.json",
    "repoCollectionsIngestHandler": "terminal/app/repo-collections-ingest-handler.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json"
  },
  "inputs": [
    "responseLoaded",
    "responseStatus",
    "verificationHead",
    "verifiedPaths",
    "currentSaveTag"
  ],
  "fields": [
    "consumed",
    "status",
    "detail",
    "saveTag",
    "verifiedHead",
    "pathsVerified",
    "trusted"
  ],
  "statusStages": "terminal-save-manager-v1.statusStages",
  "states": {
    "noVerifiedResponse": {
      "match": {
        "responseLoaded": false
      },
      "derive": {
        "consumed": false,
        "status": "disabled",
        "detail": "no-repo-verified-collections-ingest-response-loaded",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "none",
        "pathsVerified": [],
        "trusted": false
      }
    },
    "verifiedApplied": {
      "match": {
        "responseLoaded": true,
        "responseStatus": "applied"
      },
      "derive": {
        "consumed": true,
        "status": "repo-verified-applied",
        "detail": "repo-verified-collections-ingest-applied-state-from-handler-response",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "from-verified-response-head",
        "pathsVerified": "from-verified-response-paths",
        "trusted": true
      }
    },
    "verifiedRejected": {
      "match": {
        "responseLoaded": true,
        "responseStatus": "rejected"
      },
      "derive": {
        "consumed": true,
        "status": "rejected",
        "detail": "collections-ingest-handler-rejected-request",
        "saveTag": "from-current-save-tag",
        "verifiedHead": "from-verified-response-head",
        "pathsVerified": "from-verified-response-paths",
        "trusted": false
      }
    }
  },
  "guardrails": [
    "Repo-verified status must consume the authenticated collections-ingest handler response shape, not a browser-only marker.",
    "Trusted applied state depends on verified repo response content including canonical collections paths.",
    "Repo-verified state remains distinct from local staging or apply markers inside the Pages runtime.",
    "Boards are excluded because Boards never use terminal/saves/ and are not canonical collections-ingest targets."
  ]
}
