{
  "id": "terminal-request-history-surface-v1",
  "version": "v1",
  "role": "pages-runtime-save-request-history-surface-contract",
  "uses": {
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json",
    "repoVerifiedSaveStatus": "terminal/app/repo-verified-save-status.v1.json"
  },
  "inputs": [
    "currentSaveTag",
    "historyLoaded",
    "historyPath",
    "entryCount"
  ],
  "fields": [
    "consumed",
    "status",
    "saveTag",
    "historyPath",
    "entryCount",
    "detail"
  ],
  "states": {
    "noMountedSaveContext": {
      "match": {
        "currentSaveTag": null
      },
      "derive": {
        "consumed": false,
        "status": "disabled",
        "saveTag": null,
        "historyPath": "none",
        "entryCount": 0,
        "detail": "no-mounted-save-slot-context"
      }
    },
    "saveContextNoIndex": {
      "match": {
        "currentSaveTag": "non-null",
        "historyLoaded": false
      },
      "derive": {
        "consumed": false,
        "status": "awaiting-index",
        "saveTag": "from-current-save-tag",
        "historyPath": "from-history-path",
        "entryCount": 0,
        "detail": "mounted-save-slot-present-but-history-index-not-loaded"
      }
    },
    "indexedHistory": {
      "match": {
        "currentSaveTag": "non-null",
        "historyLoaded": true
      },
      "derive": {
        "consumed": true,
        "status": "indexed",
        "saveTag": "from-current-save-tag",
        "historyPath": "from-history-path",
        "entryCount": "from-entry-count",
        "detail": "request-chain-enumerated-from-repo-history-index"
      }
    }
  },
  "guardrails": [
    "History surface stays read-oriented and uses request-history-index instead of path guessing.",
    "History enumeration must not claim repo mutation by browser code alone.",
    "History surface may reference save-slot-local artifacts and governing terminal contracts only.",
    "Boards are excluded because Boards never use terminal/saves/."
  ]
}
