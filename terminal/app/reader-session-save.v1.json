{
  "id": "terminal-reader-session-save-v1",
  "version": "v1",
  "role": "reader-session-persistence-contract",
  "appliesTo": [
    "repo-cartridge",
    "disk-cartridge",
    "drag-drop-cartridge"
  ],
  "excludes": [
    "repo-board"
  ],
  "writeRoot": "terminal/saves/<tag>/",
  "repoMutationByDefault": false,
  "files": {
    "state": "terminal/saves/<tag>/state.json",
    "session": "terminal/saves/<tag>/session.json",
    "notes": "terminal/saves/<tag>/notes.json"
  },
  "state": {
    "mountedId": "string-or-null",
    "sourcePath": "string-or-null",
    "sourceClass": "string-or-null",
    "renderer": "string-or-null",
    "updatedAt": "iso-8601"
  },
  "session": {
    "page": "number-or-null",
    "scroll": "number-or-null",
    "bookmarks": [],
    "runtimeSession": "object-or-null"
  },
  "notes": {
    "items": [
      {
        "id": "string",
        "at": {
          "page": "number-or-null",
          "scroll": "number-or-null"
        },
        "text": "string",
        "createdAt": "iso-8601",
        "updatedAt": "iso-8601"
      }
    ]
  },
  "rules": [
    "Page position and scroll are terminal runtime state that may persist only through terminal/saves/<tag>/.",
    "Notes are terminal-owned state and do not edit mounted source files.",
    "Bookmarks are terminal save-state data, not repo metadata.",
    "Boards are excluded because Boards mode does not use terminal/saves/."
  ]
}
