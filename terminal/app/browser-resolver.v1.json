{
  "id": "terminal-browser-resolver-v1",
  "version": "v1",
  "role": "contract-backed-browser-runtime-resolver-layer",
  "uses": {
    "modeResolver": "terminal/loaders/mode-resolver.v1.json",
    "manifestSelection": "terminal/manifests/repo-manifest-selection.v1.json",
    "boardEnumeration": "terminal/app/board-enumeration.v1.json",
    "resumeState": "terminal/app/resume-state.v1.json",
    "actionState": "terminal/app/action-state.v1.json",
    "statusStrip": "terminal/app/status-strip.v1.json",
    "mountedViewport": "terminal/app/mounted-viewport.v1.json",
    "homeSummary": "terminal/app/home-summary.v1.json",
    "browserNoteEditor": "terminal/app/browser-note-editor.v1.json",
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "applySaveRequest": "terminal/app/apply-save-request.v1.json",
    "applySaveStatus": "terminal/app/apply-save-status.v1.json",
    "exportSource": "terminal/app/export-source.v1.json",
    "mountedSaveContext": "terminal/app/mounted-save-context.v1.json",
    "requestHistorySurface": "terminal/app/request-history-surface.v1.json",
    "repoVerifiedSaveStatus": "terminal/app/repo-verified-save-status.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json"
  },
  "loadOrder": [
    "shell-session-initial-state",
    "manifest-index",
    "board-enumeration",
    "save-slot-index",
    "mode-resolver",
    "resume-state",
    "renderer-selection",
    "action-state",
    "status-strip",
    "mounted-viewport",
    "home-summary",
    "browser-note-editor",
    "browser-save-write-bridge",
    "apply-save-request",
    "apply-save-status",
    "export-source",
    "mounted-save-context",
    "request-history-surface",
    "repo-verified-save-status",
    "repo-save-write-handler"
  ],
  "selectionFlows": {
    "manifestMount": [
      "select-manifest-index-entry",
      "load-manifest-file",
      "resolve-repo-cartridge-mode-rule",
      "resolve-renderer-rule",
      "set-mounted-session-fields",
      "refresh-derived-shell-layers"
    ],
    "boardMount": [
      "select-board-enumeration-entry",
      "resolve-board-renderer-rule",
      "set-read-only-board-session-fields",
      "refresh-derived-shell-layers"
    ],
    "saveResume": [
      "select-save-slot-index-entry",
      "load-save-files",
      "resolve-resume-state",
      "set-current-mode-runs",
      "restore-mounted-session-fields",
      "refresh-derived-shell-layers"
    ],
    "noteEdit": [
      "check-note-editor-eligibility",
      "load-or-stage-notes-payload",
      "create-or-update-note-item",
      "refresh-derived-shell-layers"
    ],
    "stageSaveWriteRequest": [
      "check-save-eligibility-and-save-tag",
      "package-state-session-notes-payloads",
      "limit-paths-to-terminal-saves-root",
      "prepare-apply-save-request-handoff",
      "refresh-apply-save-status-surface"
    ],
    "applySaveRequest": [
      "require-explicit-repo-write-consent",
      "validate-staged-request-against-apply-contract",
      "handoff-bounded-request-to-repo-save-handler",
      "refresh-apply-save-status-surface"
    ],
    "exportSource": [
      "read-mounted-source-context",
      "derive-export-source-surface",
      "download-mounted-source-without-repo-write"
    ],
    "deriveMountedSaveContext": [
      "read-current-mounted-save-context-from-dedicated-runtime-field",
      "refresh-mounted-save-context-output"
    ],
    "ingestRequestHistory": [
      "read-mounted-save-context-field-path-refs",
      "load-request-history-index-for-mounted-save-slot",
      "render-request-history-surface"
    ],
    "ingestRepoVerifiedStatus": [
      "read-mounted-save-context-field-path-refs",
      "load-optional-repo-handler-response-shape",
      "derive-repo-verified-save-status-surface"
    ],
    "repoSaveWrite": [
      "validate-request-against-repo-handler",
      "apply-bounded-save-write",
      "verify-landed-repo-state"
    ],
    "modeSwitch": [
      "set-current-mode",
      "refresh-derived-shell-layers"
    ],
    "unmount": [
      "restore-shell-initial-state",
      "refresh-derived-shell-layers"
    ]
  },
  "guardrails": [
    "Browser resolver uses landed repo contracts as runtime inputs instead of duplicating shell rules ad hoc.",
    "Manifest mounting remains repo-cartridge only.",
    "Board mounting remains approved-root live readout only.",
    "Save resume remains bounded to terminal/saves/.",
    "Browser note editing remains bounded to terminal/saves/<tag>/notes.json.",
    "Browser save-write staging remains bounded to terminal/saves/<tag>/.",
    "Apply-save-request handoff remains explicit and consent-gated.",
    "Apply-save status surface must not claim repo mutation by browser code alone.",
    "Export Source remains outbound user download behavior and distinct from Save.",
    "Mounted save context path refs are the shared runtime source for request history and repo verified status reads.",
    "Request history surface must enumerate from index data rather than path guessing.",
    "Repo-verified status must remain distinct from local apply markers.",
    "Repo save handling remains explicit, bounded, and separately validated.",
    "Browser resolver does not introduce repo writes outside terminal/saves/."
  ]
}
