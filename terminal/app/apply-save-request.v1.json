{
  "id": "terminal-apply-save-request-v1",
  "version": "v1",
  "role": "explicit-pages-collections-ingest-handoff-contract",
  "uses": {
    "saveManager": "terminal/app/save-manager.v1.json",
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "repoCollectionsIngestHandler": "terminal/app/repo-collections-ingest-handler.v1.json"
  },
  "source": "pages-runtime-staged-collections-ingest-request",
  "statusStages": "terminal-save-manager-v1.statusStages",
  "requires": {
    "stagedRequest": "terminal-browser-save-write-bridge-v1.requestShape",
    "explicitRepoWriteConsent": true,
    "packageRootMustMatch": "collections/<family>/<slug>/",
    "responseRootMustMatch": "terminal/saves/<saveTag>/"
  },
  "handoff": {
    "target": "terminal/app/repo-collections-ingest-handler.v1.json",
    "flow": [
      "validate-staged-request-shape",
      "require-explicit-repo-write-consent",
      "restrict-package-root-to-canonical-collections-family-slug",
      "restrict-response-artifacts-to-terminal-saves-saveTag",
      "handoff-bounded-request-to-collections-ingest-handler",
      "expect-collections-ingest-response-shape"
    ]
  },
  "responseShape": {
    "status": "awaiting-consent-or-handed-off-or-rejected-or-applied",
    "target": "terminal/app/repo-collections-ingest-handler.v1.json",
    "requestEcho": {
      "saveTag": "string",
      "family": "string",
      "slug": "string",
      "packageRoot": "collections/<family>/<slug>/",
      "responseRoot": "terminal/saves/<saveTag>/"
    },
    "verificationRequired": true
  },
  "guardrails": [
    "Apply-save-request remains a handoff contract, not a broad repo authoring surface.",
    "Canonical content is written under collections/<family>/<slug>/ only when the staged request passes validation and consent is explicit.",
    "Response and history sidecars remain bounded to terminal/saves/<saveTag>/ so terminal operator surfaces keep a stable inspection path.",
    "Boards remain excluded because Boards never use terminal/saves/ and are not canonical collections-ingest targets."
  ]
}
