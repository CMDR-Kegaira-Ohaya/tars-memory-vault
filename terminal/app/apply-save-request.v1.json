{
  "id": "terminal-apply-save-request-v1",
  "version": "v1",
  "role": "explicit-pages-save-request-handoff-contract",
  "uses": {
    "browserSaveWriteBridge": "terminal/app/browser-save-write-bridge.v1.json",
    "repoSaveWriteHandler": "terminal/app/repo-save-write-handler.v1.json"
  },
  "source": "pages-runtime-staged-save-request",
  "requires": {
    "stagedRequest": "terminal-browser-save-write-bridge-v1.requestShape",
    "explicitRepoWriteConsent": true
  },
  "handoff": {
    "target": "terminal/app/repo-save-write-handler.v1.json",
    "flow": [
      "validate-staged-request-shape",
      "require-explicit-repo-write-consent",
      "restrict-write-root-to-terminal-saves-tag",
      "handoff-bounded-request-to-repo-handler",
      "expect-repo-handler-response-shape"
    ]
  },
  "responseShape": {
    "status": "awaiting-consent-or-handed-off-or-rejected-or-applied",
    "target": "terminal/app/repo-save-write-handler.v1.json",
    "requestEcho": {
      "saveTag": "string",
      "writeRoot": "terminal/saves/<tag>/"
    },
    "verificationRequired": true
  },
  "guardrails": [
    "Apply-save-request remains a handoff contract, not a broad repo authoring surface.",
    "The handoff remains bounded to terminal/saves/<tag>/ only.",
    "Boards are excluded because Boards never use terminal/saves/.",
    "A staged Pages request still requires explicit repo write consent before repo-side execution."
  ]
}
